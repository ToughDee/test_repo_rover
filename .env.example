# Neo4j
# Docker/local: bolt://localhost:7687
# Aura: neo4j+s://<your-db-id>.databases.neo4j.io (copy from Aura "Connection URI")
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# LLM (OpenAI-compatible)
# Free options often include Groq/OpenRouter; set base_url accordingly.
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=PUT_YOUR_KEY_HERE
LLM_MODEL=llama-3.3-70b-versatile

# Embeddings
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_DIR=.chroma

# Ingestion
WORK_DIR=.work

